# Environment variables for Django

# Keep this secret in production!
# Gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Mínimo de 32 caracteres — nunca exponha em produção!
DJANGO_SECRET_KEY="substitua-por-uma-chave-gerada-com-no-minimo-32-chars"

# True para desenvolvimento, False para produção
DJANGO_DEBUG=True

# Hosts separados por vírgula (Ex: 127.0.0.1,localhost,seudominio.com)
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# Database Configuration
DB_NAME=ENFERMARIA_DB
DB_USER=postgres
DB_PASSWORD=sua-senha-do-banco-aqui
DB_HOST=127.0.0.1
DB_PORT=5432

